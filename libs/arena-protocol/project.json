{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "arena-protocol",
  "projectType": "library",
  "sourceRoot": "libs/arena-protocol/src",
  "tags": ["scope:shared", "type:protocol", "platform:neutral"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/libs/arena-protocol"],
      "options": {
        "command": "tsc -p libs/arena-protocol/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/libs/arena-protocol"],
      "options": {
        "cwd": "libs/arena-protocol",
        "command": "vitest run"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc --noEmit -p libs/arena-protocol/tsconfig.lib.json",
          "tsc --noEmit -p libs/arena-protocol/tsconfig.spec.json"
        ],
        "parallel": false
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint libs/arena-protocol --deny-warnings"
      }
    }
  }
}
