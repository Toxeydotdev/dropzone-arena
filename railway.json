{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm exec -- nx run server:build --configuration=production --outputStyle=static",
    "watchPatterns": [
      ".nvmrc",
      "apps/server/**",
      "libs/arena-engine/**",
      "libs/arena-protocol/**",
      "tools/deployment/**",
      "nx.json",
      "package-lock.json",
      "package.json",
      "railway.json",
      "tsconfig.base.json",
      "tsconfig.json"
    ]
  },
  "deploy": {
    "startCommand": "node dist/apps/server/main.js",
    "numReplicas": 1,
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
